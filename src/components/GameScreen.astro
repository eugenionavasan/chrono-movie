---
// Main play screen: HUD, cropped trailer player, timer and the timeline.
---

<section id="screen-game" class="screen">
  <header class="hud">
    <div class="hud-block">
      <span class="hud-label">EJE</span>
      <span class="hud-value"><span id="placed-count">1</span><span class="hud-sub">/ 10</span></span>
    </div>
    <div class="hud-title">CHRONO<span class="dot">·</span>MOVIE</div>
    <div class="hud-block">
      <span class="hud-label">INTENTOS</span>
      <span class="hud-value"><span id="attempts-count">0</span><span class="hud-sub">/ 20</span></span>
    </div>
  </header>

  <!-- Player + timer -->
  <div class="player-wrap">
    <div class="player-frame">
      <div id="yt-player"></div>
      <!-- block interaction so YouTube UI / title never appears on click -->
      <div class="player-block"></div>
      <!-- extra masks to crop any chrome that leaks in -->
      <div class="mask mask-top"></div>
      <div class="mask mask-bottom"></div>
      <div class="now-playing">🔍 ¿De qué año es este tráiler?</div>
    </div>
    <div class="timer-bar">
      <div id="timer-fill" class="timer-fill"></div>
      <span id="timer-text" class="timer-text">30</span>
    </div>
    <button id="btn-mute" class="mute-btn" title="Silenciar / activar sonido">🔊</button>
  </div>

  <!-- Timeline -->
  <div class="timeline-scroll">
    <div id="timeline" class="timeline"></div>
  </div>
  <p id="feedback" class="feedback"></p>
</section>
