---
// Win / lose screen with the "play again" button.
// The title/subtitle text is filled in by the game script.
---

<section id="screen-end" class="screen">
  <div class="end-inner">
    <h1 id="end-title" class="end-title">YOU WIN</h1>
    <p id="end-sub" class="end-sub"></p>
    <div class="end-actions">
      <button id="btn-again" class="cine-btn">
        <span class="cine-btn__label">↺ PLAY AGAIN</span>
      </button>
      <button id="btn-home" class="cine-btn cine-btn--ghost">
        <span class="cine-btn__label">⌂ INICIO</span>
      </button>
    </div>
  </div>
</section>
