---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = 'CHRONO·MOVIE — Línea cronológica de cine' } = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="description" content="Juego para construir una línea cronológica del cine adivinando el año de cada película." />
    <title>{title}</title>
    <link rel="preconnect" href="https://image.tmdb.org" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Oswald:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <!-- Film grain / vignette overlays -->
    <div class="vignette"></div>
    <div class="grain"></div>

    <slot />
  </body>
</html>
